      "id": "68",
      "source_id": "100",
      "type": "single",
      "question": "Which type of network attack overwhelms the target server by sending multiple packets to a port\nuntil the half-open TCP resources of the target are exhausted?",
      "question_images": [],
      "options": {
        "A": "SYN flood",
        "B": "reflection",
        "C": "teardrop",
        "D": "amplification"
      },
      "answer": [
        "A"
      ],
      "answer_images": [],
      "explanation": "A SYN flood (half-open attack) is a type of denial-of-service (DDoS) attack which aims to make a\nserver unavailable to legitimate traffic by consuming all available server resources. By repeatedly\nsending initial connection request (SYN) packets, the attacker is able to overwhelm all available\nports on a targeted server machine, causing the targeted device to respond to legitimate traffic\nsluggishly or not at all.",
      "explanation_images": [],
      "question_vi": "Loại tấn công mạng nào làm quá tải server đích bằng cách gửi nhiều packet đến một port cho đến khi tài nguyên TCP half-open của đích bị cạn kiệt?",
      "options_vi": {
        "A": "SYN flood",
        "B": "Reflection",
        "C": "Teardrop",
        "D": "Amplification"
      }
    },
