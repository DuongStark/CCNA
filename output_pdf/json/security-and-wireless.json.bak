      "id": "108",
      "source_id": "2",
      "type": "single",
      "question": "Which WPA3 enhancement protects against hackers viewing traffic on the Wi-Fi network?",
      "question_images": [],
      "options": {
        "A": "TKIP encryption",
        "B": "AES encryption",
        "C": "Scrambled encryption key",
        "D": "SAE encryption"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "Wi-Fi Protected Access version 3 (WPA3) is a new Wi-Fi Alliance’s (WFA) security standard for\npersonal and enterprise networks. It aims to improve overall Wi-Fi security by using modern\nsecurity algorithms and stronger cipher suites. WPA3 has two parts:\n+ WPA3-Personal: Uses simultaneous authentication of equals (SAE) instead of pre-shared\nkey (PSK), providing users with stronger security protections against attacks such as offline\ndictionary attacks, key recovery, and message forging.\n+ WPA3-Enterprise: Offers stronger authentication and link-layer encryption methods, and an\noptional 192-bit security mode for sensitive security environments.",
      "explanation_images": [],
      "question_vi": "Tính năng nâng cao nào của WPA3 bảo vệ chống lại hacker xem traffic trên mạng Wi-Fi?",
      "options_vi": {
        "A": "Mã hóa TKIP",
        "B": "Mã hóa AES",
        "C": "Khóa mã hóa bị xáo trộn",
        "D": "Mã hóa SAE"
      }
    },
    {
      "id": "109",
      "source_id": "3",
      "type": "single",
      "question": "What is a difference between local AP mode and FlexConnet AP mode?",
      "question_images": [],
      "options": {
        "A": "Local AP mode creates two CAPWAP tunnels per AP to the WLC",
        "B": "FlexConnect AP mode fails to function if me AP loses connectivity with the WLC",
        "C": "FlexConnect AP mode bridges the traffic from the AP to the WLC when local switching is\nconfigured",
        "D": "Local AP mode causes the AP to behave as if it were an autonomous AP"
      },
      "answer": [
        "A"
      ],
      "answer_images": [],
      "explanation": "In Central Switched (Local) mode, an AP creates two CAPWAP tunnels to the Wireless Controller.\nOne tunnel is used for forwarding data traffic and the other is used for forwarding the\nmanagement traffic.",
      "explanation_images": [],
      "question_vi": "Sự khác biệt giữa chế độ local AP và chế độ FlexConnect AP là gì?",
      "options_vi": {
        "A": "Chế độ local AP tạo hai CAPWAP tunnel trên mỗi AP đến WLC",
        "B": "Chế độ FlexConnect AP ngừng hoạt động nếu AP mất kết nối với WLC",
        "C": "Chế độ FlexConnect AP bridge traffic từ AP đến WLC khi local switching được cấu hình",
        "D": "Chế độ local AP khiến AP hoạt động như thể nó là autonomous AP"
      }
    },
