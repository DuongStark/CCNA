    {
      "id": "172",
      "source_id": "15",
      "type": "single",
      "question": "Which cipher is supported for wireless encryption only with the WPA2 standard?",
      "question_images": [],
      "options": {
        "A": "AES256",
        "B": "AES",
        "C": "RC4",
        "D": "SHA"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "Unlike WEP and WPA, WPA2 uses the AES standard instead of the Rivest Cipher 4 (RC4) stream\ncipher.\nWPA3-Enterprice mode uses AES-256 in GCM mode.\nSHA stands for Secure Hash Algorithm while AES stands for Advanced Encryption Standard. So\nSHA is a suite of hashing algorithms. It is not a cipher which is used to encrypt.",
      "explanation_images": [],
      "question_vi": "Cipher nào chỉ được hỗ trợ cho mã hóa wireless với tiêu chuẩn WPA2?",
      "options_vi": {
        "A": "AES256",
        "B": "AES",
        "C": "RC4",
        "D": "SHA"
      }
    },
    {
      "id": "173",
      "source_id": "22",
      "type": "single",
      "question": "Which enhancement is implemented in WPA3?",
      "question_images": [],
      "options": {
        "A": "applies 802.1x authentication",
        "B": "uses TKIP",
        "C": "employs PKI to identify access points",
        "D": "protects against brute force attacks"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "Another security enhancement that has been made in WP3 reduces potential for password cracking\nattacks such as the WPA2 KRACK Attack. WPA2 is vulnerable to brute force and dictionary-based\nattacks. That is because security relies on the AP provider setting a secure password and many\nestablishments don’t. With WPA3, the Pre-Shared Key (PSK) exchange protocol is replaced with\nSimultaneous Authentication of Equals (SAE) or the Dragonfly Key Exchange, which improves\nsecurity of the initial key exchange and offers better protection against offline dictionary-based\nattacks.\nReference: https://www.webtitan.com/blog/wpa3-wifi-security-enhancements-will-not-block-all-\nthreats/",
      "explanation_images": [],
      "question_vi": "Tính năng nâng cao nào được triển khai trong WPA3?",
      "options_vi": {
        "A": "Áp dụng xác thực 802.1x",
        "B": "Sử dụng TKIP",
        "C": "Sử dụng PKI để xác định access point",
        "D": "Bảo vệ chống lại tấn công brute force"
      }
    },
    {
      "id": "174",
      "source_id": "35",
      "type": "single",
      "question": "How does encryption protect the wireless network?",
      "question_images": [],
      "options": {
        "A": "via integrity checks to identify wireless forgery attacks in the frame",
        "B": "via specific ciphers to detect and prevent zero-day network attacks",
        "C": "via an algorithm to change wireless data so that only the access point and client understand it",
        "D": "via a policy to prevent unauthorized users from communicating on the wireless network"
