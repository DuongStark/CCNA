    {
      "id": "13",
      "source_id": "5",
      "type": "single",
      "question": "Refer to the exhibit. An administrator configures the following ACL in order to prevent devices on\nthe 192.168.1.0 subnet from accessing the server at 10.1.1.5:\naccess-list 100 deny ip 192.168.1.0 0.0.0.255 host 10.1.1.5\naccess-list 100 permit ip any any\nWhere should the administrator place this ACL for the most efficient use of network resources?",
      "question_images": [],
      "options": {
        "A": "inbound on router A Fa0/0",
        "B": "outbound on router B Fa0/0",
        "C": "outbound on router A Fa0/1",
        "D": "inbound on router B Fa0/1"
      },
      "answer": [
        "A"
      ],
      "answer_images": [],
      "explanation": "By placing the ACL closest to the source, we can reduce unnecessary traffic passing between two\nrouters and the processing time of the router.",
      "explanation_images": [],
      "question_vi": "Tham khảo hình minh họa. Một quản trị viên cấu hình ACL sau để ngăn các thiết bị trên subnet 192.168.1.0 truy cập vào server tại 10.1.1.5:\naccess-list 100 deny ip 192.168.1.0 0.0.0.255 host 10.1.1.5\naccess-list 100 permit ip any any\nQuản trị viên nên đặt ACL này ở đâu để sử dụng tài nguyên mạng hiệu quả nhất?",
      "options_vi": {
        "A": "Inbound trên router A Fa0/0",
        "B": "Outbound trên router B Fa0/0",
        "C": "Outbound trên router A Fa0/1",
        "D": "Inbound trên router B Fa0/1"
      }
    },
