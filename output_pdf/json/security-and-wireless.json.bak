    {
      "id": "130",
      "source_id": "3",
      "type": "single",
      "question": "How does WPA3 improve security?",
      "question_images": [],
      "options": {
        "A": "It uses SAE for authentication.",
        "B": "It uses a 4-way handshake for authentication.",
        "C": "It uses RC4 for encryption.",
        "D": "It uses TKIP for encryption."
      },
      "answer": [
        "A"
      ],
      "answer_images": [],
      "explanation": "WPA3 incorporates Simultaneous Authentication of Equals (SAE), a secure key establishment\nprotocol between devices. By using a stronger ‘handshaking’ protocol, users should be protected\nfrom password guessing attempts. For home networks, that equates to password-based\nauthentication that’s more resilient, even if users choose unsophisticated passwords.",
      "explanation_images": [],
      "question_vi": "WPA3 cải thiện bảo mật như thế nào?",
      "options_vi": {
        "A": "Nó sử dụng SAE để xác thực.",
        "B": "Nó sử dụng 4-way handshake để xác thực.",
        "C": "Nó sử dụng RC4 để mã hóa.",
        "D": "Nó sử dụng TKIP để mã hóa."
      }
    },
