      "id": "137",
      "source_id": "29",
      "type": "single",
      "question": "Which 802.11 frame type is indicated by a probe response after a client sends a probe request?",
      "question_images": [],
      "options": {
        "A": "action",
        "B": "management",
        "C": "control",
        "D": "data"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "There are three main types of 802.11 frames: the Data Frame, the Management Frame and the\nControl Frame. Association Response belongs to Management Frame. Association response is sent\nin response to an association request.",
      "explanation_images": [],
      "question_vi": "Loại frame 802.11 nào được chỉ ra bởi probe response sau khi client gửi probe request?",
      "options_vi": {
