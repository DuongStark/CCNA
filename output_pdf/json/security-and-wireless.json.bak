      "id": "149",
      "source_id": "59",
      "type": "single",
      "question": "Which port type does a lightweight AP use to connect to the wired network when configured in\nFlexConnect mode with local switching and VLAN tagging?",
      "question_images": [],
      "options": {
        "A": "EtherChannel",
        "B": "access",
        "C": "LAG",
        "D": "trunk"
      },
      "answer": [
