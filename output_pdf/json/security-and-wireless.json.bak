    {
      "id": "54",
      "source_id": "3",
      "type": "single",
      "question": "Which type of attack can be mitigated by dynamic ARP inspection?",
      "question_images": [],
      "options": {
        "A": "malware",
        "B": "DDoS",
        "C": "worm",
        "D": "man-in-the-middle"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "ARP attack (like ARP poisoning/spoofing, man-in-the-middle) is a type of attack in which a\nmalicious actor sends falsified ARP messages over a local area network as ARP allows a gratuitous\nreply from a host even if an ARP request was not received. This results in the linking of an\nattacker’s MAC address with the IP address of a legitimate computer or server on the network.\nThis is an attack based on ARP which is at Layer 2. Dynamic ARP inspection (DAI) is a security\nfeature that validates ARP packets in a network which can be used to mitigate this type of attack.",
      "explanation_images": [],
      "question_vi": "Loại tấn công nào có thể được giảm thiểu bằng dynamic ARP inspection?",
      "options_vi": {
        "A": "Malware",
        "B": "DDoS",
        "C": "Worm",
        "D": "Man-in-the-middle"
      }
    },
    {
      "id": "55",
      "source_id": "4",
      "type": "single",
      "question": "Which technology is used to improve web traffic performance by proxy caching?",
      "question_images": [],
      "options": {
        "A": "Firepower",
        "B": "FireSIGHT",
        "C": "ASA",
        "D": "WSA (Web Security Appliance)"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "The Web Security appliance (WSA) intercepts requests that are forwarded to it by clients or other\ndevices over the network. Proxy caching is a setting in WSA that caches data to increase\nperformance.",
      "explanation_images": [],
      "question_vi": "Công nghệ nào được sử dụng để cải thiện hiệu suất web traffic bằng proxy caching?",
      "options_vi": {
        "A": "Firepower",
        "B": "FireSIGHT",
        "C": "ASA",
        "D": "WSA (Web Security Appliance)"
      }
    },
    {
      "id": "56",
      "source_id": "5",
      "type": "single",
      "question": "Which device performs stateful inspection of traffic?",
      "question_images": [],
      "options": {
        "A": "access point",
        "B": "switch",
        "C": "wireless controller",
        "D": "firewall"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "In stateful inspection, the firewall not only inspects packets up through the application layer/layer7\ndetermining a packet’s header information and data content, but also monitors and keeps track of\nthe connection’s state. For all active connections traversing the firewall, the state information,\nwhich may include IP addresses and ports involved, the sequence numbers and acknowledgement\nnumbers of the packets traversing the connection, TCP packet flags, etc. is maintained in a state\ntable.",
      "explanation_images": [],
      "question_vi": "Thiết bị nào thực hiện stateful inspection của traffic?",
      "options_vi": {
        "A": "Access point",
        "B": "Switch",
        "C": "Wireless controller",
        "D": "Firewall"
      }
    },
    {
      "id": "57",
      "source_id": "6",
      "type": "multi",
      "question": "What are two recommendations for protecting network ports from being exploited when located in\nan office space outside of an IT closet? (Choose two)",
      "question_images": [],
      "options": {
        "A": "shut down unused ports",
