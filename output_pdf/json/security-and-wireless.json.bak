    {
      "id": "120",
      "source_id": "3",
      "type": "single",
      "question": "An engineer observes high usage on the 2.4GHz channels and lower usage on the 5GHz channels.\nWhat must be configured to allow clients to preferentially use 5GHz access points?",
      "question_images": [],
      "options": {
        "A": "Client Band Select",
        "B": "OEAP Split Tunnel",
        "C": "11ac MU-MIMO",
        "D": "Re-Anchor Roamed Clients"
      },
      "answer": [
        "A"
      ],
      "answer_images": [],
      "explanation": "Band selection works by regulating probe responses to clients and it can be enabled on a per-\nWLAN basis. It makes 5-GHz channels more attractive to clients by delaying probe responses to\nclients on 2.4-GHz channels.\nReference: https://www.cisco.com/c/en/us/td/docs/wireless/controller/8-3/config-\nguide/b_cg83/b_cg83_chapter_011100.html",
      "explanation_images": [],
      "question_vi": "Một kỹ sư quan sát thấy mức sử dụng cao trên các kênh 2.4 GHz và mức sử dụng thấp hơn trên các kênh 5 GHz. Cần cấu hình gì để cho phép các client ưu tiên sử dụng các access point 5 GHz?",
      "options_vi": {
        "A": "Client Band Select",
        "B": "OEAP Split Tunnel",
        "C": "11ac MU-MIMO",
        "D": "Re-Anchor Roamed Clients"
      }
    },
