      "id": "145",
      "source_id": "110",
      "type": "single",
      "question": "What is a function of Opportunistic Wireless Encryption in an environment?",
      "question_images": [],
      "options": {
        "A": "offer compression",
        "B": "increase security by using a WEP connection",
        "C": "provide authentication",
        "D": "protect traffic on open networks"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "Opportunistic Wireless Encryption (OWE) is an extension to IEEE 802.11 that provides encryption\nof the wireless medium. The purpose of OWE based authentication is avoid open unsecured\nwireless connectivity between the AP’s and clients. The OWE uses the Diffie-Hellman algorithms\nbased Cryptography to setup the wireless encryption.\nReference: https://www.cisco.com/c/en/us/td/docs/wireless/controller/9800/16-12/config-\nguide/b_wl_16_12_cg/wpa3.html",
      "explanation_images": [],
      "question_vi": "Chức năng của Opportunistic Wireless Encryption trong một môi trường là gì?",
      "options_vi": {
        "A": "Cung cấp nén dữ liệu",
        "B": "Tăng cường bảo mật bằng cách sử dụng kết nối WEP",
        "C": "Cung cấp xác thực",
        "D": "Bảo vệ traffic trên các mạng mở"
      }
    },
