    {
      "id": "104",
      "source_id": "10",
      "type": "single",
      "question": "Which 802.11 frame type is association response?",
      "question_images": [],
      "options": {
        "A": "management",
        "B": "protected frame",
        "C": "control",
        "D": "action"
      },
      "answer": [
        "A"
      ],
      "answer_images": [],
      "explanation": "There are three main types of 802.11 frames: the Data Frame, the Management Frame and the\nControl Frame. Association Response belongs to Management Frame. Association response is sent\nin response to an association request.",
      "explanation_images": [],
      "question_vi": "Loại frame 802.11 nào là association response?",
      "options_vi": {
        "A": "Management",
        "B": "Protected frame",
        "C": "Control",
        "D": "Action"
      }
    },
