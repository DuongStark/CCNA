    {
      "id": "99",
      "source_id": "5",
      "type": "single",
      "question": "Which statement about Link Aggregation when implemented on a Cisco Wireless LAN Controller is\ntrue?",
      "question_images": [],
      "options": {
        "A": "To pass client traffic two or more ports must be configured",
        "B": "The EtherChannel must be configured in “mode active”",
        "C": "When enabled the WLC bandwidth drops to 500 Mbps",
        "D": "One functional physical port is needed to pass client traffic"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "Link aggregation (LAG) is a partial implementation of the 802.3ad port aggregation standard. It\nbundles all of the controller’s distribution system ports into a single 802.3ad port channel.\nRestriction for Link aggregation:\n+ LAG requires the EtherChannel to be configured for ‘mode on’ on both the controller and the\nCatalyst switch -> Answer B is not correct.\n+ If the recommended load-balancing method cannot be configured on the Catalyst switch, then\nconfigure the LAG connection as a single member link or disable LAG on the controller ->\nAnswer A is not correct while answer D is correct.\nReference: https://www.cisco.com/c/en/us/td/docs/wireless/controller/7-5/configuration-\nguide/b_cg75/b_cg75_chapter_0100010.html",
      "explanation_images": [],
      "question_vi": "Phát biểu nào về Link Aggregation khi được triển khai trên Cisco Wireless LAN Controller là đúng?",
      "options_vi": {
        "A": "Để truyền traffic client cần cấu hình hai port trở lên",
        "B": "EtherChannel phải được cấu hình ở \"mode active\"",
        "C": "Khi được bật, băng thông WLC giảm xuống còn 500 Mbps",
        "D": "Chỉ cần một port vật lý hoạt động để truyền traffic client"
      }
    },
    {
      "id": "100",
      "source_id": "6",
      "type": "single",
      "question": "Which mode allows access points to be managed by Cisco Wireless LAN Controllers?",
      "question_images": [],
      "options": {
        "A": "autonomous",
        "B": "lightweight",
        "C": "bridge",
        "D": "mobility express"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "A Lightweight Access Point (LAP) is an AP that is designed to be connected to a wireless LAN\n(WLAN) controller (WLC). APs are “lightweight,” which means that they cannot act independently\nof a wireless LAN controller (WLC). The WLC manages the AP configurations and firmware. The APs\nare “zero touch” deployed, and individual configuration of APs is not necessary.\nReference: https://www.cisco.com/c/en/us/support/docs/wireless/aironet-1200-series/70278-lap-\nfaq.html",
      "explanation_images": [],
      "question_vi": "Chế độ nào cho phép access point được quản lý bởi Cisco Wireless LAN Controller?",
      "options_vi": {
        "A": "Autonomous",
        "B": "Lightweight",
        "C": "Bridge",
        "D": "Mobility express"
      }
    },
