    {
      "id": "168",
      "source_id": "90",
      "type": "single",
      "question": "What does WPA3 provide in wireless networking?",
      "question_images": [],
      "options": {
        "A": "increased security and requirement of a complex configuration",
        "B": "backward compatibility with WPA and WPA2",
        "C": "optional Protected Management Frame negotiation",
        "D": "safeguards against brute force attacks with SAE"
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "WPA3 only backwards compatible with WPA2 but not WPA -> Answer B is not correct.\nWPA3 increases security but not require a complex configuration -> Answer A is not correct.\nSimultaneous Authentication of Equals (SAE): SAE provides a more secure, password-based\nauthentication and key agreement mechanism even when passwords are not following complexity\nrequirements. It protects from brute-force attacks and makes unwanted decrypting of sessions\n(during or after the session) a lot harder – just knowing the passphrase isn’t enough to decrypt\nthe session -> Answer D is correct.\nReference: https://www.mist.com/wpa3-just-the-essentials-on-the-latest-in-wi-fi-security/",
      "explanation_images": [],
      "question_vi": "WPA3 cung cấp gì trong mạng wireless?",
      "options_vi": {
        "A": "Tăng cường bảo mật và yêu cầu cấu hình phức tạp",
        "B": "Tương thích ngược với WPA và WPA2",
        "C": "Thương lượng Protected Management Frame tùy chọn",
        "D": "Bảo vệ chống lại tấn công brute force bằng SAE"
      }
    },
    {
      "id": "169",
      "source_id": "94",
      "type": "single",
      "question": "A WLC sends alarms about a rogue AP, and the network administrator verifies that the alarms are\ncaused by a legitimate autonomous AP. How must the alarms be stopped for the MAC address of\nthe AP?",
      "question_images": [],
      "options": {
        "A": "Place the AP into manual containment.",
        "B": "Remove the AP from WLC management.",
        "C": "Manually remove the AP from Pending state.",
        "D": "Set the AP Class Type to Friendly."
      },
      "answer": [
        "D"
      ],
      "answer_images": [],
      "explanation": "If a rogue AP is classified as friendly, it means that the rogue AP exists in the vicinity, is a known\nAP, and need not be tracked. Therefore, all the rogue clients are either deleted or not tracked if\nthey are associated with the friendly rogue AP.\nReference: https://content.cisco.com/chapter.sjs?uri=/searchable/chapter/content/en/us/td/docs/\nwireless/controller/7-5/configuration-guide/b_cg75/b_cg75_chapter_0111010.html.xml",
      "explanation_images": [],
      "question_vi": "WLC gửi cảnh báo về một rogue AP, và quản trị viên mạng xác minh rằng các cảnh báo được gây ra bởi một autonomous AP hợp lệ. Làm thế nào để dừng các cảnh báo cho MAC address của AP đó?",
      "options_vi": {
        "A": "Đặt AP vào manual containment.",
        "B": "Xóa AP khỏi quản lý WLC.",
        "C": "Xóa thủ công AP khỏi trạng thái Pending.",
        "D": "Đặt AP Class Type thành Friendly."
      }
    },
