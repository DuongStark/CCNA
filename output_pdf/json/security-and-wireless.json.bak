      "id": "3",
      "source_id": "3",
      "type": "single",
      "question": "A port security violation has occurred on a switch port due to the maximum MAC address count\nbeing exceeded. Which command must be configured to increment the security-violation count and\nforward an SNMP trap?",
      "question_images": [],
      "options": {
        "A": "switchport port-security violation access",
        "B": "switchport port-security violation restrict",
        "C": "switchport port-security violation protect",
        "D": "switchport port-security violation shutdown"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": null,
      "explanation_images": [],
      "question_vi": "Một vi phạm port security đã xảy ra trên một port của switch do vượt quá số lượng MAC address tối đa. Lệnh nào phải được cấu hình để tăng bộ đếm security-violation và gửi SNMP trap?",
      "options_vi": {
        "A": "switchport port-security violation access",
        "B": "switchport port-security violation restrict",
        "C": "switchport port-security violation protect",
        "D": "switchport port-security violation shutdown"
      }
