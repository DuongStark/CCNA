    {
      "id": "138",
      "source_id": "30",
      "type": "single",
      "question": "What is recommended for the wireless infrastructure design of an organization?",
      "question_images": [],
      "options": {
        "A": "group access points together to increase throughput on a given channel",
        "B": "configure the first three access points are configured to use channels 1, 6, and 11",
        "C": "include a least two access points on nonoverlapping channels to support load balancing",
        "D": "assign physically adjacent access points to the same Wi-Fi channel"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "The 2.4 GHz band is subdivided into multiple channels each allotted 22 MHz bandwidth and\nseparated from the next channel by 5 MHz.\n-> A best practice for 802.11b/g/n WLANs requiring multiple APs is to use non-overlapping\nchannels such as 1, 6, and 11.\nIf you use channels that overlap, RF interference can occur.\nReference: https://www.cisco.com/c/en/us/support/docs/wireless/aironet-340-series/8117-\nconnectivity.html",
      "explanation_images": [],
      "question_vi": "Điều gì được khuyến nghị cho thiết kế hạ tầng wireless của một tổ chức?",
      "options_vi": {
        "A": "Nhóm các access point lại với nhau để tăng throughput trên một kênh nhất định",
        "B": "Cấu hình ba access point đầu tiên sử dụng kênh 1, 6 và 11",
        "C": "Bao gồm ít nhất hai access point trên các kênh không chồng lấp để hỗ trợ cân bằng tải",
        "D": "Gán các access point liền kề về mặt vật lý vào cùng kênh Wi-Fi"
      }
    },
    {
      "id": "139",
      "source_id": "46",
      "type": "single",
      "question": "Which wireless security protocol relies on Perfect Forward Secrecy?",
      "question_images": [],
      "options": {
        "A": "WPA",
        "B": "WPA3",
        "C": "WPA2",
        "D": "WEP"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "WPA3 (Wi-Fi Protected Access 3) is the newest wireless security protocol designed to encrypt data\nusing a frequent and automatic encryption type called Perfect Forward Secrecy. It’s more secure\nthan its predecessor, WPA2, but it hasn’t been widely adopted yet. Not all hardware supports\nWPA3 automatically, and using this protocol often requires costly upgrades.\nReference: https://www.avast.com/c-wep-vs-wpa-or-wpa2",
      "explanation_images": [],
      "question_vi": "Giao thức bảo mật wireless nào dựa vào Perfect Forward Secrecy?",
      "options_vi": {
        "A": "WPA",
        "B": "WPA3",
        "C": "WPA2",
        "D": "WEP"
      }
    },
    {
      "id": "140",
      "source_id": "57",
      "type": "single",
      "question": "What is a requirement when configuring or removing LAG on a WLC?",
      "question_images": [],
      "options": {
        "A": "The incoming and outgoing ports for traffic flow must be specified if LAG is enabled.",
        "B": "The controller must be rebooted after enabling or reconfiguring LAG.",
        "C": "The management interface must be reassigned if LAG is disabled.",
        "D": "Multiple untagged interfaces on the same port must be supported."
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "When you enable LAG or make any changes to the LAG configuration, you must immediately\nreboot the controller.\nReference: https://www.cisco.com/c/en/us/td/docs/wireless/controller/7-\n4/configuration/guides/consolidated/b_cg74_CONSOLIDATED/b_cg74_CONSOLIDATED_chapter_0\n10100001.html",
      "explanation_images": [],
      "question_vi": "Yêu cầu nào khi cấu hình hoặc xóa LAG trên WLC?",
      "options_vi": {
        "A": "Các port đến và đi cho luồng traffic phải được chỉ định nếu LAG được bật.",
        "B": "Controller phải được khởi động lại sau khi bật hoặc cấu hình lại LAG.",
        "C": "Management interface phải được gán lại nếu LAG bị tắt.",
        "D": "Phải hỗ trợ nhiều interface không được gắn thẻ trên cùng một port."
      }
    },
    {
      "id": "141",
      "source_id": "58",
      "type": "single",
      "question": "What is a requirement for nonoverlapping WI-FI channels?",
      "question_images": [],
      "options": {
        "A": "different security settings",
        "B": "different transmission speeds",
        "C": "discontinuous frequency ranges",
        "D": "unique SSIDs"
      },
      "answer": [
        "C"
      ],
      "answer_images": [],
      "explanation": "Each channel on the 2.4 GHz spectrum is 20 MHz wide. The channel centers are separated by 5\nMHz, and the entire spectrum is only 100 MHz wide. This means the 11 channels have to squeeze\ninto the 100 MHz available, and in the end, overlap. Channels 1, 6, and 11, however, are far\nenough from each other on the 2.4GHz band that they have sufficient space between their channel\ncenters and do not overlap.",
      "explanation_images": [],
      "question_vi": "Yêu cầu nào cho các kênh Wi-Fi không chồng lấp?",
      "options_vi": {
        "A": "Cài đặt bảo mật khác nhau",
