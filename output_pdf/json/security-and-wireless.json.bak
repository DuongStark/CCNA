    {
      "id": "83",
      "source_id": "89",
      "type": "single",
      "question": "Which IPsec transport mode encrypts the IP header and the payload?",
      "question_images": [],
      "options": {
        "A": "pipe",
        "B": "tunnel",
        "C": "control",
        "D": "transport"
      },
      "answer": [
        "B"
      ],
      "answer_images": [],
      "explanation": "In tunnel mode, the entire original IP packet is encapsulated to become the payload of a new IP\npacket. Additionally, a new IP header is added on top of the original IP packet.\nThe main difference in transport mode is that it retains the original IP header. In other words,\npayload data transmitted within the original IP packet is protected, but not the IP header.\nReference: https://www.twingate.com/blog/ipsec-tunnel-mode/",
      "explanation_images": [],
      "question_vi": "Chế độ transport nào của IPsec mã hóa cả IP header và payload?",
      "options_vi": {
        "A": "Pipe",
        "B": "Tunnel",
        "C": "Control",
        "D": "Transport"
      }
    },
